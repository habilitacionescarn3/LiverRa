{
  "name": "@liverra/fhirtypes",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "FHIR R4 TypeScript types with LiverRa extensions (ImagingStudy, DiagnosticReport, AuditEvent, …)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./r4": {
      "types": "./dist/r4/index.d.ts",
      "import": "./dist/r4/index.js"
    },
    "./liverra": {
      "types": "./dist/liverra/index.d.ts",
      "import": "./dist/liverra/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist src/r4/generated",
    "generate:fhir-types": "tsx scripts/generate-fhir-types.ts",
    "lint": "eslint ."
  },
  "dependencies": {},
  "devDependencies": {}
}
