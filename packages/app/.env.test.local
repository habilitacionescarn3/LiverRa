# LiverRa — test-mode env overrides (gitignored).
#
# Vite uses `.env.[mode].local` for the given mode, so when Vitest runs
# with mode=test these values override `.env.local`. Without this file,
# `VITE_LIVERRA_DEV_BYPASS=true` from `.env.local` leaks into the test
# process and short-circuits the early-return branches in RefinementView
# (seat-taken, record-lock, no-permission) — those branches are guarded
# by `!devBypass`, so the test setup never exercises them.

VITE_LIVERRA_DEV_BYPASS=false
VITE_LIVERRA_MOCK_API=false
