# Netlify env vars for liverra-app.netlify.app.
# Copy to scripts/netlify-env.env, fill the values, then run:
#
#   netlify env:import scripts/netlify-env.env --context production
#
# DO NOT commit netlify-env.env.

# Point the SPA at the Fly.io backend.
VITE_LIVERRA_API_BASE_URL=https://liverra-api.fly.dev/api/v1

# Real auth in production — never bypass.
VITE_LIVERRA_DEV_BYPASS=false
VITE_LIVERRA_MOCK_API=false

# DICOMweb endpoint — Orthanc lives behind the same Fly.io domain (if/when
# you expose Orthanc) or via a separate tunnel. For pure testing without
# DICOM browsing, leave this pointing at a placeholder.
VITE_DICOM_WEB_BASE=https://liverra-api.fly.dev/dicom-web

# Supabase Auth client config (for the frontend login form).
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-key>

# Posthog/Sentry — optional, leave empty if not used.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
