# Netlify env vars for liverra-app.netlify.app.
# Copy to scripts/netlify-env.env, fill the values, then run:
#
#   netlify env:import scripts/netlify-env.env --context production
#
# DO NOT commit netlify-env.env.

# Point the SPA at the Fly.io backend.
VITE_LIVERRA_API_BASE_URL=https://liverra-api.fly.dev/api/v1

# Real auth in production — never bypass.
VITE_LIVERRA_DEV_BYPASS=false
VITE_LIVERRA_MOCK_API=false

# Shared staging credentials gate. When both are set, /signin renders a
# working credential form; on submit, localStorage:liverra:staging-auth=ok
# admits the user as the mock dev-bypass user. Remove both lines to disable
# the gate (form fields render disabled, no way in without OIDC).
VITE_LIVERRA_STAGING_EMAIL=<shared-staging-email>
VITE_LIVERRA_STAGING_PASSWORD=<shared-staging-password>

# DICOMweb endpoint — Orthanc on Fly.io is fronted by a proxy router on
# liverra-api (packages/ml-inference/src/api/dicomweb.py). The router
# validates the Cognito JWT then forwards to a private Orthanc on the
# Fly internal 6PN network. See deploy/fly/orthanc/.
VITE_DICOM_WEB_BASE=https://liverra-api.fly.dev/dicom-web

# Anonymization-sidecar bypass — required on staging because the
# `anon_sidecar` service is not deployed in cloud yet. Without this var
# set, StudyImporter.tsx fail-closes on every /pacs/studies upload to
# protect PHI. Remove this once you deploy the sidecar and set
# VITE_LIVERRA_ANON_SIDECAR_URL=https://<sidecar-host>.
VITE_LIVERRA_ANON_SIDECAR_BYPASS=true

# Supabase Auth client config (for the frontend login form).
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<supabase-anon-public-key>

# Posthog/Sentry — optional, leave empty if not used.
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
