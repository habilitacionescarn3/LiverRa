# Fly.io secrets for liverra-api.
# Copy to scripts/fly-secrets.env, fill the real values, then run:
#
#   fly secrets set --app liverra-api $(grep -v '^\s*#' scripts/fly-secrets.env | xargs)
#
# DO NOT commit fly-secrets.env (it's gitignored).
# All values are placeholders — replace each <...>.

# --- Database (Supabase Frankfurt, "Connection string → Transaction pooler") -
# Get from Supabase dashboard → Project Settings → Database → Connection string.
# Use the IPv4-friendly "pooler" endpoint for Fly.io.
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL_SYNC=postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Redis (Upstash, EU region) ----------------------------------------------
# Get from Upstash dashboard → Databases → liverra-redis → Connect → "redis://"
CELERY_BROKER_URL=redis://default:<password>@<host>.upstash.io:6379
# Celery result backend = same Postgres so task state survives broker restarts.
CELERY_RESULT_BACKEND=db+postgresql://postgres.<ref>:<password>@aws-0-eu-central-1.pooler.supabase.com:5432/postgres

# --- Object storage (Cloudflare R2, S3-compatible) ---------------------------
# Get from Cloudflare dashboard → R2 → Manage R2 API tokens → "S3 Auth Tokens"
AWS_ENDPOINT_URL=https://<r2-account-id>.r2.cloudflarestorage.com
AWS_ACCESS_KEY_ID=<r2-access-key>
AWS_SECRET_ACCESS_KEY=<r2-secret-key>
AWS_REGION=auto
LIVERRA_PHASES_BUCKET=liverra-phases-staging
LIVERRA_ANALYSES_BUCKET=liverra-analyses-staging

# --- GPU inference (Irakli's PC, exposed via Tailscale Funnel) --------------
# Irakli runs `tailscale funnel --bg 9101` and sends you the URL + token.
# Update these two values when he replies.
LIVERRA_INFERENCE_URL=https://<machine>.<tailnet>.ts.net
LIVERRA_GPU_SHARED_TOKEN=<48-byte-token-shared-with-irakli>

# --- Auth (Supabase Auth replaces Cognito for testing) -----------------------
# Get from Supabase dashboard → Project Settings → API.
# The "issuer URL" is "<project-url>/auth/v1" and "audience" is "authenticated".
COGNITO_ISSUER_URL=https://<ref>.supabase.co/auth/v1
COGNITO_AUDIENCE=authenticated

# --- Frontend origin (for CORS) ---------------------------------------------
# Comma-separated. Override the in-code default if you add a custom domain.
CORS_ORIGINS=https://liverra-app.netlify.app,https://liverra.netlify.app

# --- Orthanc (private PACS on Fly internal 6PN) ------------------------------
# The DICOMweb proxy router (src/api/dicomweb.py) and the Celery task
# (src/tasks/ingest_tasks.py) both use these to talk to liverra-orthanc.
# `flycast` is Fly's internal DNS for app-to-app traffic over WireGuard.
# Set ORTHANC_PASSWORD via `fly secrets set --app liverra-orthanc` first,
# then mirror the SAME value on liverra-api below.
ORTHANC_URL=http://liverra-orthanc.flycast:8042
ORTHANC_USERNAME=liverra-api
ORTHANC_PASSWORD=<openssl rand -base64 32 — must match liverra-orthanc>

# --- Ingest auto-cascade gate -------------------------------------------------
# When true, every finished /upload tus session enqueues the
# `study_upload_complete` Celery task which pushes to Orthanc and
# dispatches the AI cascade. Defaults to FALSE on local dev so the
# laptop doesn't auto-trigger a 13-minute cascade per test upload.
# MUST be set to "true" on Fly for the published version to work.
LIVERRA_INGEST_AUTO_CASCADE=true

# --- Sentry (optional but recommended for testing) ---------------------------
SENTRY_DSN=
