{
  "title": "LiverRa — Users",
  "uid": "liverra-users",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "timezone": "utc",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "tags": ["liverra", "users"],
  "templating": {
    "list": [
      {
        "name": "tenant",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(liverra_active_sessions, tenant_id)",
        "includeAll": true,
        "multi": true
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Active sessions (24h rolling)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (tenant_id) (liverra_active_sessions{tenant_id=~\"$tenant\"})",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Reviewer-seat acquisitions",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum by (tenant_id) (rate(liverra_seat_acquired_total{tenant_id=~\"$tenant\"}[5m]))",
          "legendFormat": "{{tenant_id}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Step-up MFA events",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(liverra_step_up_total[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    }
  ]
}
