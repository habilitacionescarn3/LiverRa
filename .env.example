# LiverRa Environment Configuration
# Copy this file to .env and fill in real values. DO NOT commit .env.

# ==============================================================================
# AWS (eu-central-1 Frankfurt for GDPR residency)
# ==============================================================================
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# S3 bucket for DICOM storage (created in deploy phase)
S3_DICOM_BUCKET=

# ==============================================================================
# Supabase (auth + Postgres + Edge Functions)
# ==============================================================================
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ==============================================================================
# Medplum FHIR (optional — may use self-hosted instead)
# ==============================================================================
VITE_MEDPLUM_BASE_URL=https://api.medplum.com/
VITE_MEDPLUM_CLIENT_ID=
VITE_MEDPLUM_PROJECT_ID=

# ==============================================================================
# Orthanc PACS (edge appliance)
# ==============================================================================
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=

# ==============================================================================
# ML Inference Service
# ==============================================================================
ML_INFERENCE_URL=http://localhost:8000
TRITON_URL=http://localhost:8001
MODEL_REGISTRY_PATH=./packages/ml-inference/models

# ==============================================================================
# App Configuration
# ==============================================================================
VITE_APP_NAME=LiverRa
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:8000
PORT=3000

# ==============================================================================
# Observability (optional)
# ==============================================================================
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
WANDB_API_KEY=

# ==============================================================================
# Feature Flags
# ==============================================================================
VITE_ENABLE_RESEARCH_USE_DISCLAIMER=true
VITE_ENABLE_INTERACTIVE_REFINEMENT=true
