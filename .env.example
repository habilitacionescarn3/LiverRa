# LiverRa Environment Configuration
# Copy this file to .env and fill in real values. DO NOT commit .env.
# Secrets in production live in AWS Secrets Manager (eu-central-1), never in .env.

# ==============================================================================
# AWS (eu-central-1 Frankfurt for GDPR residency — Constitution VII)
# ==============================================================================
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SECRETS_MANAGER_PREFIX=liverra/

# S3 buckets
S3_DICOM_BUCKET=
S3_ARTIFACTS_BUCKET=
S3_AUDIT_BUCKET=
S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
S3_FORCE_PATH_STYLE=false

# KMS
KMS_KEY_ALIAS_PREFIX=alias/liverra/case/
KMS_MASTER_KEY_ID=

# ==============================================================================
# Auth — AWS Cognito (research §A.1)
# ==============================================================================
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_CLIENT_SECRET=
COGNITO_DOMAIN=
COGNITO_REGION=eu-central-1

# ==============================================================================
# FHIR — Medplum self-hosted (research §A.2)
# ==============================================================================
MEDPLUM_BASE_URL=http://localhost:8103/
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
MEDPLUM_PROJECT_ID=
VITE_MEDPLUM_BASE_URL=http://localhost:8103/
VITE_MEDPLUM_CLIENT_ID=

# ==============================================================================
# Postgres (RDS in production, local container in dev)
# ==============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=liverra
POSTGRES_PASSWORD=liverra
POSTGRES_DB=liverra
POSTGRES_SSL_MODE=prefer
DATABASE_URL=postgresql://liverra:liverra@localhost:5432/liverra

# ==============================================================================
# Redis / Elasticache (Celery + session cache — research §A.7)
# ==============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==============================================================================
# Orthanc PACS (edge appliance — research §B.3)
# ==============================================================================
ORTHANC_URL=http://localhost:8042
ORTHANC_USERNAME=orthanc
ORTHANC_PASSWORD=orthanc
ORTHANC_DICOMWEB_ROOT=http://localhost:8042/dicom-web

# Dev-only Vite proxy credentials (see vite.config.ts). The browser never
# sees these; the proxy injects Basic auth server-side.
ORTHANC_DEV_USER=orthanc
ORTHANC_DEV_PASSWORD=orthanc
ORTHANC_DEV_ORIGIN=http://127.0.0.1:8042

# Orthanc Lua hook sidecar. Leave unset in local dev so the hook accepts
# every instance without calling a webhook. Production sets it so the
# anonymization sidecar runs and the fail-closed path engages.
LIVERRA_ANON_SIDECAR_URL=

# Frontend DICOMweb base. Relative path (`/dicom-web`) in dev rides the
# Vite proxy; absolute in prod points at the nginx terminus.
VITE_DICOM_WEB_BASE=/dicom-web

# ==============================================================================
# ML Inference Service (FastAPI + Triton)
# ==============================================================================
ML_INFERENCE_URL=http://localhost:8000
TRITON_URL=http://localhost:8001
TRITON_GRPC_URL=localhost:8001
TRITON_HTTP_URL=http://localhost:8000
MODEL_REGISTRY_PATH=./packages/ml-inference/triton-models

# ==============================================================================
# GPU Inference Microservice (Option B split, 2026-05-09)
# ==============================================================================
# The cascade calls this URL via src/services/inference_client.py to run
# TotalSegmentator on Irakli's RTX 3090 box. See packages/ml-inference-gpu/.
# Port 9101 — 9100 is silently dropped by the Tailscale ACL (see
# CLAUDE.md "Tailscale ACL gotcha"); 9000 is reserved for MinIO.
LIVERRA_INFERENCE_URL=http://100.124.94.29:9101
LIVERRA_INFERENCE_TIMEOUT_S=1800
# Bearer token shared with the GPU service. Generate with
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# and set the IDENTICAL value on both the laptop AND the GPU box via
# LIVERRA_GPU_SHARED_TOKEN. The GPU service refuses to start without it.
LIVERRA_GPU_SHARED_TOKEN=
# Whether a PAID TotalSegmentator commercial license for the
# "liver_vessels" subtask has been confirmed for this deployment.
# Default false → gated endpoints return HTTP 451. Setting this true is
# a legal attestation the license was actually purchased from the TS
# authors — do NOT flip it as a convenience. See CLAUDE.md
# "Model Licensing Discipline".
LIVERRA_TS_COMMERCIAL_LICENSED=false
# Internal-demo / clinical-validation escape hatch. true → the gated
# liver_vessels + total_and_vessels endpoints are unlocked under the TS
# weights' CC-BY-NC-SA-4.0 NON-commercial terms, and every response is
# stamped X-LiverRa-License-Mode=noncommercial-demo so the audit trail
# never implies a commercial license. This is NOT a license
# attestation. MUST stay false on any paying-customer deployment.
LIVERRA_TS_NONCOMMERCIAL_DEMO=false
# Set to "true" to re-enable the dormant Triton inference path
# (src/tasks/{couinaud,vessels}.py). Default unset → cascade uses
# the TotalSegmentator GPU microservice exclusively.
LIVERRA_TRITON_PATH_ACTIVE=

# DICOM UID root (acquired per runbook scripts/ops/acquire-dicom-oid.md)
LIVERRA_UID_ROOT=

# ==============================================================================
# Email — AWS SES (research §A.5)
# ==============================================================================
SES_REGION=eu-central-1
SES_FROM_ADDRESS=no-reply@liverra.ai
SES_CONFIGURATION_SET=liverra-default
SMTP_HOST=localhost
SMTP_PORT=1025

# ==============================================================================
# Observability (research §A.6)
# ==============================================================================
SENTRY_DSN=
SENTRY_DSN_DEV=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_DSN=

POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.posthog.com
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://eu.posthog.com

OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=liverra
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=development

# ==============================================================================
# App Configuration
# ==============================================================================
VITE_APP_NAME=LiverRa
VITE_APP_ENV=development
VITE_API_BASE_URL=http://localhost:8000
PORT=5173

# ==============================================================================
# Deployment targeting (set by scripts/switch-env.sh)
# ==============================================================================
DOCKER_COMPOSE_FILE=deploy/local/docker-compose.yml
LIVERRA_DEPLOY_TARGET=local

# ==============================================================================
# Feature Flags
# ==============================================================================
VITE_ENABLE_RESEARCH_USE_DISCLAIMER=true
VITE_ENABLE_INTERACTIVE_REFINEMENT=true

# ==============================================================================
# Cascade Sanity Bounds (C-CASCADE-1, H-CASCADE-5)
# When true, any heuristic-stage output that violates its numeric
# invariants (FLR>total, negative volumes, classification confidence
# outside [0, 1], etc.) FAILS the cascade loudly. When false / unset,
# violations log a warning and the cascade continues.
# Recommended: true in staging / prod, false in dev for fast iteration.
# ==============================================================================
LIVERRA_REQUIRE_SANITY=false

# ==============================================================================
# Triton path (legacy / dormant)
# Set to true ONLY when running the dormant Triton inference path.
# Default (unset / false): skips Triton model-stub SHA detection at
# worker startup (L-CASCADE-2). The live cascade uses TotalSegmentator
# via the GPU microservice instead.
# ==============================================================================
LIVERRA_TRITON_PATH_ACTIVE=false
